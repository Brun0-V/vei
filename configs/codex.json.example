{
  "mcpServers": {
    "vision-inventory": {
      "command": "python3",
      "args": ["/path/to/VEI/vision_inventory_mcp.py"],
      "env": {
        "CLOUDFLARE_ACCOUNT_ID": "your_cloudflare_account_id",
        "CLOUDFLARE_AUTH_TOKEN": "your_cloudflare_workers_ai_token"
      }
    }
  }
}

# Place in ~/.codex/settings.json or project .codex/settings.json
